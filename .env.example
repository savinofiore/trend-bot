# ---------------------------------------------------------------------------
# trend-bot configuration — copy to .env and fill in. NEVER commit .env.
# ---------------------------------------------------------------------------

# --- Safety switches -------------------------------------------------------
# Both default to the SAFE value. Only the literal string "false" flips them.
# Anything else ("true", "1", "", unset) is treated as the safe mode.
# Mainnet live trading requires BOTH set explicitly to false.
DRY_RUN=true
BYBIT_TESTNET=true

# Skip the interactive confirmation for --no-dry-run (CI / cron use only).
TRENDBOT_NON_INTERACTIVE=0

# --- Bybit API (private client) --------------------------------------------
# Use a key WITHOUT withdrawal permission. The bot refuses to start otherwise.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Supabase (observability only, never authoritative state) --------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram notifications ------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Execution loop tuning -------------------------------------------------
RECONCILE_INTERVAL_SEC=300
POST_ONLY_TIMEOUT_SEC=60
IDLE_POLL_SEC=15

# Sentinel file that keeps a logical HALT sticky across container restarts.
# Must live on a persistent volume so `restart: always` cannot revive a halt.
TRENDBOT_HALT_FILE=/data/trendbot.halt
